{
  "name": "@webdeveric/eslint-config-mono-repo",
  "private": true,
  "packageManager": "pnpm@11.2.0+sha512.cdd7e34ea0d237bed3fa89e633185027e3ecdad98ce7453032f4d4d83c10cb7b85b9afe8534048ab0a3cc10228bdd5e32f5f622d05d66e58f46177fe5601eab1",
  "scripts": {
    "lerna": "lerna",
    "clean": "lerna clean",
    "lint": "lerna run lint",
    "spellcheck": "cspell --no-progress './**/*'",
    "format": "prettier --write ./**/*.json ./packages/**/*.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --cache --fix"
    ],
    "*.{js,json,md}": [
      "cspell --no-progress --no-summary --no-must-find-files",
      "prettier --write"
    ]
  },
  "prettier": "@webdeveric/prettier-config",
  "devDependencies": {
    "@webdeveric/prettier-config": "^0.4.0",
    "cspell": "^10.0.0",
    "eslint": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  }
}
