{
  "name": "@webdeveric/eslint-config-mono-repo",
  "private": true,
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "lerna": "lerna",
    "clean": "lerna clean",
    "lint": "lerna run lint",
    "spellcheck": "cspell --no-progress './**/*'",
    "format": "prettier --write ./**/*.json ./packages/**/*.js",
    "validate": "validate-package-exports --info --check ./packages/*/package.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --cache --fix"
    ],
    "*.{js,json,md}": [
      "cspell --no-progress --no-summary --no-must-find-files",
      "prettier --write"
    ]
  },
  "prettier": "@webdeveric/prettier-config",
  "devDependencies": {
    "@webdeveric/prettier-config": "^0.4.0",
    "cspell": "^10.0.1",
    "eslint": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "validate-package-exports": "^1.2.0"
  }
}
